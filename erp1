                        ${c.balance > 0 ? `<button class="btn btn-sm btn-success" onclick="recordCreditPayment('${c.id}', prompt('Enter payment amount:', '${c.balance}'))"><i class="fas fa-hand-holding-usd"></i> Pay</button>` : '<span class="badge badge-success">Paid</span>'}
