        <div style="margin-top:12px;font-size:0.55rem;color:#a0aec0;text-align:center;border-top:1px solid #e2e8f0;padding-top:8px;">Samodeda Limited · Complete ERP · POS + Credit + All Modules</div>
    </div>

    <script>
        // ========================== SECURITY & MULTI-USER ==========================
        let userDB = JSON.parse(localStorage.getItem('samodeda_users')) || {
            'admin': { password: 'admin123', role: 'administrator', display: 'Admin' },
            'manager': { password: 'manager123', role: 'manager', display: 'Manager' },
            'cashier': { password: 'cash123', role: 'cashier', display: 'Cashier' }
        };

        function saveUserDB() { localStorage.setItem('samodeda_users', JSON.stringify(userDB)); }

        let currentUser = null, sessionToken = null, sessionStart = null;

        function generateSessionToken(u){ return CryptoJS.SHA256(`${u}:${Date.now()}:${Math.random().toString(36).substring(2,10)}`).toString(CryptoJS.enc.Hex).substring(0,32); }
        function generateTransactionToken(type,data,u){ return CryptoJS.SHA256(`${type}:${JSON.stringify(data)}:${Date.now()}:${Math.random().toString(36).substring(2,10)}:${u}`).toString(CryptoJS.enc.Hex); }

        function login(u,p){
            const user = userDB[u];
            if(!user || user.password !== p) return false;
            currentUser = u;
            sessionToken = generateSessionToken(u);
            sessionStart = Date.now();
            document.getElementById('loginOverlay').classList.add('hidden');
            document.getElementById('currentUserDisplay').textContent = user.display || u;
            document.getElementById('sessionTokenDisplay').textContent = sessionToken.substring(0,16)+'…';
            logAudit('login', `User ${u} logged in`, 0, u, 'system');
            localStorage.setItem('samodeda_current_user', u);
            renderAll();
            return true;
        }

        function logout(){
            if(currentUser) logAudit('logout', `User ${currentUser} logged out`, 0, currentUser, 'system');
            currentUser = null; sessionToken = null; sessionStart = null;
            localStorage.removeItem('samodeda_current_user');
            document.getElementById('loginOverlay').classList.remove('hidden');
            document.getElementById('loginError').style.display = 'none';
        }

        function isSessionValid(){ return !(!currentUser||!sessionToken||(Date.now()-sessionStart)>8*60*60*1000); }

        // ========================== SYNC ==========================
        let syncChannel = null;
        let lastDataHash = '';

        function initSyncChannel() {
            try {
                syncChannel = new BroadcastChannel('samodeda_sync');
                syncChannel.onmessage = function(event) {
                    if (event.data && event.data.type === 'update') {
                        loadAllData();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                };
            } catch (e) { startPolling(); }
        }

        let pollInterval = null;
        function startPolling() {
            if (pollInterval) clearInterval(pollInterval);
            pollInterval = setInterval(() => {
                const currentHash = getDataHash();
                if (currentHash !== lastDataHash) {
                    lastDataHash = currentHash;
                    loadAllData();
                    renderAll();
                    updateSyncStatus('Synced');
                }
            }, 3000);
        }

        function getDataHash() {
            const data = {
                products: products.map(p => ({sku:p.sku, sold:p.sold, restocked:p.restocked, opening:p.opening})),
                sales: sales.map(s => ({saleId:s.saleId, total:s.total, date:s.date})),
                credit: creditSales.map(c => ({id:c.id, total:c.total, balance:c.balance})),
                restocks: restocks.map(r => ({id:r.id, qty:r.qty, product:r.product})),
                ledger: ledgerEntries.map(l => ({id:l.id, date:l.date})),
                journals: journalEntries.map(j => ({id:j.id, date:j.date}))
            };
            return CryptoJS.SHA256(JSON.stringify(data)).toString(CryptoJS.enc.Hex).substring(0, 16);
        }

        function broadcastUpdate() {
            if (syncChannel) { try { syncChannel.postMessage({ type: 'update', timestamp: Date.now() }); } catch(e) {} }
            lastDataHash = getDataHash();
        }

        function updateSyncStatus(status) {
            const el = document.getElementById('syncText');
            const icon = document.querySelector('.sync-status i');
            if (el) {
                el.textContent = status;
                if (status === 'Synced') {
                    document.querySelector('.sync-status').className = 'sync-status';
                    if (icon) icon.className = 'fas fa-cloud-upload-alt';
                } else if (status === 'Syncing...') {
                    document.querySelector('.sync-status').className = 'sync-status syncing';
                    if (icon) icon.className = 'fas fa-sync-alt';
                }
            }
        }

        function loadAllData() {
            const storedProducts = localStorage.getItem('samodeda_products');
            const storedSales = localStorage.getItem('samodeda_sales');
            const storedCredit = localStorage.getItem('samodeda_credit');
            const storedRestocks = localStorage.getItem('samodeda_restocks');
            const storedAudit = localStorage.getItem('samodeda_audit');
            const storedCounter = localStorage.getItem('samodeda_saleIdCounter');
            const storedMisc = localStorage.getItem('samodeda_misc');
            const storedLedger = localStorage.getItem('samodeda_ledger');
            const storedJournals = localStorage.getItem('samodeda_journals');
            const storedPriceHistory = localStorage.getItem('samodeda_price_history');
            const storedSuppliers = localStorage.getItem('samodeda_suppliers');
            const storedCustomers = localStorage.getItem('samodeda_customers');
            const storedTax = localStorage.getItem('samodeda_tax');
            const storedBudget = localStorage.getItem('samodeda_budget');

            if (storedProducts) { try { const parsed = JSON.parse(storedProducts); if (Array.isArray(parsed) && parsed.length > 0) products = parsed; } catch(e) {} }
            if (storedSales) { try { const parsed = JSON.parse(storedSales); if (Array.isArray(parsed)) sales = parsed; } catch(e) {} }
            if (storedCredit) { try { const parsed = JSON.parse(storedCredit); if (Array.isArray(parsed)) creditSales = parsed; } catch(e) {} }
            if (storedRestocks) { try { const parsed = JSON.parse(storedRestocks); if (Array.isArray(parsed)) restocks = parsed; } catch(e) {} }
            if (storedAudit) { try { const parsed = JSON.parse(storedAudit); if (Array.isArray(parsed)) auditLog = parsed; } catch(e) {} }
            if (storedCounter) { try { const parsed = JSON.parse(storedCounter); if (typeof parsed === 'number') saleIdCounter = parsed; } catch(e) {} }
            if (storedMisc) { try { const parsed = JSON.parse(storedMisc); if (Array.isArray(parsed)) miscEntries = parsed; } catch(e) {} }
            if (storedLedger) { try { const parsed = JSON.parse(storedLedger); if (Array.isArray(parsed)) ledgerEntries = parsed; } catch(e) {} }
            if (storedJournals) { try { const parsed = JSON.parse(storedJournals); if (Array.isArray(parsed)) journalEntries = parsed; } catch(e) {} }
            if (storedPriceHistory) { try { const parsed = JSON.parse(storedPriceHistory); if (Array.isArray(parsed)) priceHistory = parsed; } catch(e) {} }
            if (storedSuppliers) { try { const parsed = JSON.parse(storedSuppliers); if (Array.isArray(parsed)) suppliers = parsed; } catch(e) {} }
            if (storedCustomers) { try { const parsed = JSON.parse(storedCustomers); if (Array.isArray(parsed)) customers = parsed; } catch(e) {} }
            if (storedTax) { try { const parsed = JSON.parse(storedTax); if (Array.isArray(parsed)) taxEntries = parsed; } catch(e) {} }
            if (storedBudget) { try { const parsed = JSON.parse(storedBudget); if (Array.isArray(parsed)) budgetEntries = parsed; } catch(e) {} }
            const storedUsers = localStorage.getItem('samodeda_users');
            if (storedUsers) { try { const parsed = JSON.parse(storedUsers); if (typeof parsed === 'object' && Object.keys(parsed).length > 0) userDB = parsed; } catch(e) {} }
            lastDataHash = getDataHash();
        }

        // ========================== DATA ==========================
        const fullInventoryData = [
            {sku:'P-001',name:'TOTIO BABY WIPES',category:'Baby Care',cost:14.8125,price:19.26,opening:80,reorderLevel:6},
