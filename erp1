        function applyBulkPriceUpdate() {
            if (!currentUser) { alert('Please login first.'); return; }
            const action = document.getElementById('priceUpdateAction').value;
            const value = parseFloat(document.getElementById('priceUpdateValue').value);
            const category = document.getElementById('priceUpdateCategory').value;
            if (!value || value <= 0) { alert('Please enter a valid value.'); return; }
            let targetProducts = category === 'all' ? products : products.filter(p => p.category === category);
            if (targetProducts.length === 0) { alert('No products found for the selected category.'); return; }
            targetProducts.forEach(p => {
                const oldPrice = p.price; const oldCost = p.cost;
                switch(action) {
                    case 'percent': p.price = p.price * (1 + value / 100); break;
                    case 'margin': p.price = p.cost * (1 + value / 100); break;
                    case 'fixed': p.price = p.cost + value; break;
                    case 'new': p.price = value; break;
                }
                priceHistory.push({ date: todayStr(), product: p.name, action: action, oldPrice: oldPrice, newPrice: p.price, oldCost: oldCost, newCost: p.cost, user: currentUser });
            });
            saveState();
            logAudit('pricing', `Bulk price update: ${targetProducts.length} products updated (${action})`, 0, currentUser, 'system');
            renderInventory(); renderPricingHistory();
            alert(`✅ ${targetProducts.length} products updated.`);
        }

        function renderPricingHistory() {
            const container = document.getElementById('priceChangeHistory');
            if (priceHistory.length === 0) {
                container.innerHTML = '<div style="color:#a0aec0;text-align:center;padding:10px;">No price changes recorded yet</div>';
                return;
