        // ========================== REPORT GENERATION ==========================
        function getReportFilters() {
            const from = document.getElementById('reportDateFrom').value;
            const to = document.getElementById('reportDateTo').value;
            const user = document.getElementById('reportUserFilter').value;
            return { from, to, user };
        }

        function filterByDate(data, dateField, from, to) {
            if (!from && !to) return data;
            return data.filter(item => {
                const d = item[dateField] || '';
                if (from && d < from) return false;
                if (to && d > to) return false;
                return true;
            });
        }

        function filterByUser(data, userField, user) {
            if (user === 'all' || !user) return data;
            return data.filter(item => (item[userField] || '') === user);
        }

        function generateReport(reportType, format) {
            if (!currentUser) { alert('Please login first.'); return; }
            const filters = getReportFilters();
            let data = [], filename = '', headers = [], rows = [];

            switch(reportType) {
                case 'sales':
                    let salesData = filterByDate([...sales], 'date', filters.from, filters.to);
                    salesData = filterByUser(salesData, 'user', filters.user);
                    data = salesData; filename = `sales_report_${todayStr()}`;
                    headers = ['Receipt', 'Date', 'User', 'Customer', 'Items', 'Total', 'Payment', 'Status'];
                    rows = data.map(s => [s.saleId||'', s.date||'', s.user||'system', s.customer||'—', (s.items||[]).map(i=>`${i.productName}x${i.qty}`).join('; '), s.total||0, s.payment||'', s.status||'Paid']);
                    break;
                case 'credit':
                    let creditData = filterByDate([...creditSales], 'date', filters.from, filters.to);
                    creditData = filterByUser(creditData, 'user', filters.user);
                    data = creditData; filename = `credit_report_${todayStr()}`;
                    headers = ['Invoice', 'Date', 'Customer', 'Total', 'Paid', 'Balance', 'Status'];
                    rows = data.map(c => [c.id||'', c.date||'', c.customer||'', c.total||0, c.paid||0, c.balance||0, c.status||'unpaid']);
                    break;
                case 'restock':
                    let restockData = filterByDate([...restocks], 'date', filters.from, filters.to);
                    restockData = filterByUser(restockData, 'user', filters.user);
                    data = restockData; filename = `restock_report_${todayStr()}`;
                    headers = ['Date', 'User', 'Product', 'Qty', 'Total Cost'];
                    rows = data.map(r => [r.date||'', r.user||'system', r.product||'', r.qty||0, r.totalCost||0]);
                    break;
                case 'ledger':
                    let ledgerData = filterByDate([...ledgerEntries], 'date', filters.from, filters.to);
                    ledgerData = filterByUser(ledgerData, 'user', filters.user);
                    data = ledgerData; filename = `ledger_report_${todayStr()}`;
                    headers = ['Date', 'Description', 'Account', 'Debit', 'Credit', 'User'];
                    rows = data.map(e => [e.date||'', e.description||'', e.account||'Other', e.debit||0, e.credit||0, e.user||'system']);
                    break;
                case 'journal':
                    let journalData = filterByDate([...journalEntries], 'date', filters.from, filters.to);
                    journalData = filterByUser(journalData, 'user', filters.user);
                    data = journalData; filename = `journal_report_${todayStr()}`;
                    headers = ['Date', 'Description', 'Account', 'Debit', 'Credit', 'User'];
                    rows = data.map(j => [j.date||'', j.description||'', j.account||'Other', j.debit||0, j.credit||0, j.user||'system']);
                    break;
                case 'tax':
                    let taxData = filterByDate([...taxEntries], 'date', filters.from, filters.to);
                    taxData = filterByUser(taxData, 'user', filters.user);
                    data = taxData; filename = `tax_report_${todayStr()}`;
                    headers = ['Date', 'Description', 'Type', 'Rate', 'Amount', 'User'];
                    rows = data.map(t => [t.date||'', t.description||'', t.type||'', t.rate||0, t.amount||0, t.user||'system']);
                    break;
                case 'summary':
                    const totalSales = sales.reduce((s,x) => s + x.total, 0);
                    const totalProfit = sales.reduce((s,x) => s + x.profit, 0);
                    const totalExpenses = miscEntries.reduce((s,x) => s + x.amount, 0);
                    const netProfit = totalProfit - totalExpenses;
                    const stockValue = products.reduce((s,p) => s + getStock(p) * p.cost, 0);
                    const totalCredit = creditSales.reduce((s,c) => s + c.total, 0);
                    const outstanding = creditSales.reduce((s,c) => s + c.balance, 0);
                    data = [{
                        'Total Revenue': totalSales, 'Total Profit': totalProfit, 'Total Expenses': totalExpenses,
                        'Net Profit': netProfit, 'Stock Value': stockValue, 'Total Credit Sales': totalCredit,
                        'Outstanding Receivables': outstanding, 'Total Products': products.length,
                        'Total Sales': sales.length, 'Total Restocks': restocks.length,
                        'Low Stock Items': products.filter(p => getStatus(p) === '⚠️ Low').length,
                        'Out of Stock': products.filter(p => getStatus(p) === '❌ Out').length
                    }];
                    filename = `summary_report_${todayStr()}`;
                    headers = Object.keys(data[0]);
                    rows = [Object.values(data[0])];
                    break;
                default: alert('Unknown report type'); return;
            }

            if (rows.length === 0) { alert('No data found for the selected filters.'); return; }

            if (format === 'csv') {
                let csv = headers.join(',') + '\n';
                rows.forEach(row => { csv += row.map(cell => typeof cell === 'string' && (cell.includes(',')||cell.includes('"')) ? '"'+cell.replace(/"/g,'""')+'"' : cell).join(',') + '\n'; });
                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob); link.download = `${filename}.csv`; link.click();
                URL.revokeObjectURL(link.href);
                alert(`✅ ${reportType} report downloaded as CSV`);
            } else if (format === 'json') {
                const json = JSON.stringify(data, null, 2);
                const blob = new Blob([json], { type: 'application/json;charset=utf-8;' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob); link.download = `${filename}.json`; link.click();
                URL.revokeObjectURL(link.href);
                alert(`✅ ${reportType} report downloaded as JSON`);
            } else if (format === 'pdf') {
                try {
                    const { jsPDF } = window.jspdf;
                    const doc = new jsPDF('landscape', 'mm', 'a4');
                    const pageWidth = doc.internal.pageSize.getWidth();
                    doc.setFontSize(14); doc.setTextColor(26,26,46);
                    doc.text(`Samodeda Ltd - ${reportType.charAt(0).toUpperCase() + reportType.slice(1)} Report`, pageWidth/2, 12, { align: 'center' });
                    doc.setFontSize(8); doc.setTextColor(100,100,120);
                    const dateRange = filters.from && filters.to ? `${filters.from} to ${filters.to}` : 'All dates';
                    doc.text(`Generated: ${new Date().toLocaleString()} | ${dateRange}`, pageWidth/2, 18, { align: 'center' });
                    const tableRows = rows.map(row => row.map(cell => String(cell)));
                    doc.autoTable({ head: [headers], body: tableRows, startY: 22, styles: { fontSize: 6, cellPadding: 1.5 }, headStyles: { fillColor: [26,26,46], textColor: [255,255,255], fontSize: 6 } });
                    doc.save(`${filename}.pdf`);
                    alert(`✅ ${reportType} report downloaded as PDF`);
                } catch(e) { alert('PDF generation failed: ' + e.message); }
            }
        }

