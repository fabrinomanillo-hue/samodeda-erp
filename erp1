        function getStatus(p){ const s=getStock(p); if(s<=0) return '❌ Out'; if(s<=p.reorderLevel) return '⚠️ Low'; return '✅ OK'; }
        function todayStr(){ return new Date().toISOString().slice(0,10); }
        function ksh(v){ if(v===undefined||v===null||isNaN(v)) return 'KSh 0'; return 'KSh '+Number(v).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,','); }
        function ksh2(v){ return 'KSh '+Number(v).toFixed(2); }
        function logAudit(type,details,amount,username,token){ const entry={id:'AUD-'+String(Date.now()).slice(-8)+'-'+String(Math.random().toString(36).substring(2,6)).toUpperCase(),timestamp:Date.now(),type,details,amount:amount||0,username:username||currentUser||'system',token:token||'system',verified:true}; auditLog.push(entry); if(auditLog.length>2000) auditLog=auditLog.slice(-2000); localStorage.setItem('samodeda_audit',JSON.stringify(auditLog)); }
        function saveState(){ 
            localStorage.setItem('samodeda_products',JSON.stringify(products)); 
            localStorage.setItem('samodeda_sales',JSON.stringify(sales)); 
            localStorage.setItem('samodeda_credit',JSON.stringify(creditSales)); 
            localStorage.setItem('samodeda_restocks',JSON.stringify(restocks)); 
            localStorage.setItem('samodeda_saleIdCounter',JSON.stringify(saleIdCounter));
            localStorage.setItem('samodeda_misc',JSON.stringify(miscEntries));
            localStorage.setItem('samodeda_ledger',JSON.stringify(ledgerEntries));
            localStorage.setItem('samodeda_journals',JSON.stringify(journalEntries));
            localStorage.setItem('samodeda_price_history',JSON.stringify(priceHistory));
            localStorage.setItem('samodeda_suppliers',JSON.stringify(suppliers));
            localStorage.setItem('samodeda_customers',JSON.stringify(customers));
            localStorage.setItem('samodeda_tax',JSON.stringify(taxEntries));
            localStorage.setItem('samodeda_budget',JSON.stringify(budgetEntries));
            broadcastUpdate();
        }

        function checkLowStock(){
            const lowItems = products.filter(p => getStock(p) > 0 && getStock(p) <= p.reorderLevel);
            const outItems = products.filter(p => getStock(p) <= 0);
            const msg = document.getElementById('lowStockMessage');
            const notif = document.getElementById('lowStockNotification');
            if(lowItems.length > 0 || outItems.length > 0){
                let text = '';
                if(outItems.length > 0) text += `🚨 ${outItems.length} out of stock. `;
                if(lowItems.length > 0) text += `⚠️ ${lowItems.length} low stock items. `;
                msg.textContent = text;
                notif.style.display = 'flex';
            } else { notif.style.display = 'none'; }
        }

        function editProduct(sku,field,value){
            const p=products.find(x=>x.sku===sku); if(!p) return;
            let num=parseFloat(value);
            if(field==='name') p.name=value;
            else if(field==='category') p.category=value;
            else if(field==='cost') { if(!isNaN(num)&&num>=0) p.cost=num; }
            else if(field==='price') { if(!isNaN(num)&&num>=0) p.price=num; }
            else if(field==='opening') { if(!isNaN(num)&&num>=0) p.opening=num; }
            saveState(); renderInventory(); checkLowStock();
        }

