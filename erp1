        // ===== PRICING MODULE =====
        function addNewGoods() {
            if (!currentUser) { alert('Please login first.'); return; }
            const name = document.getElementById('newGoodsName').value.trim();
            const category = document.getElementById('newGoodsCategory').value.trim() || 'Other';
