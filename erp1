        // ===== CART =====
        function addToCart(productName,qty,price){
            const product=products.find(p=>p.name===productName);
            if(!product){ alert('Product not found!'); return; }
            const available=getStock(product);
            if(qty>available){ alert(`Only ${available.toFixed(1)} units available.`); return; }
            const finalPrice=(price&&price>0)?price:product.price;
            if(finalPrice<=0){ alert('Price must be > 0.'); return; }
            const existing=cart.find(c=>c.productName===productName);
            if(existing){ existing.qty+=qty; existing.price=finalPrice; existing.subtotal=existing.qty*existing.price; }
            else { cart.push({productName,sku:product.sku,qty,price:finalPrice,cost:product.cost,subtotal:qty*finalPrice}); }
            renderCart();
        }
        function removeFromCart(index){ cart.splice(index,1); renderCart(); }
        function updateCartItem(index,field,value){
            if(field==='qty'){ let q=parseFloat(value)||0; if(q<=0){ removeFromCart(index); return; } cart[index].qty=q; cart[index].subtotal=q*cart[index].price; }
            else if(field==='price'){ let p=parseFloat(value)||0; if(p<=0)return; cart[index].price=p; cart[index].subtotal=cart[index].qty*p; }
            renderCart();
        }
        function clearCart(){ if(cart.length===0)return; if(!confirm('Clear cart?'))return; cart=[]; renderCart(); }
        function renderCart(){
            const container=document.getElementById('cartItems'), totalEl=document.getElementById('cartTotal');
            document.getElementById('posCartCount').textContent=cart.length+' items';
            if(cart.length===0){ container.innerHTML='<div class="empty-cart"><i class="fas fa-cart-plus"></i> Add items</div>'; totalEl.textContent='KSh 0'; return; }
            let total=0;
            container.innerHTML=cart.map((item,idx)=>{ total+=item.subtotal; return `<div class="cart-item"><span class="item-name">${item.productName}</span><span class="item-qty"><input type="number" value="${item.qty}" min="0.1" step="0.1" onchange="updateCartItem(${idx},'qty',this.value)"/></span><span class="item-price"><input type="number" value="${item.price.toFixed(2)}" step="0.01" onchange="updateCartItem(${idx},'price',this.value)"/></span><span class="item-subtotal">${ksh(item.subtotal)}</span><span class="item-remove" onclick="removeFromCart(${idx})"><i class="fas fa-times-circle"></i></span></div>`; }).join('');
            totalEl.textContent=ksh(total);
        }

        function processSale(isCredit) {
            if(!currentUser)return; if(cart.length===0){ alert('Cart is empty!'); return; }
            const payment=document.getElementById('posPayment').value;
            const customer=document.getElementById('posCustomer').value.trim() || 'Walk-in';
            const date=todayStr();
            const totalSale=cart.reduce((s,i)=>s+i.subtotal,0);
            const totalCost=cart.reduce((s,i)=>s+(i.qty*i.cost),0);
            const profit=totalSale-totalCost;
            const tokenData={items:cart.map(i=>({name:i.productName,qty:i.qty,price:i.price})),total:totalSale,payment,date,user:currentUser};
            const token=generateTransactionToken('sale',tokenData,currentUser);
            const sale={saleId:'SL-'+String(saleIdCounter++).padStart(5,'0'),date,user:currentUser,customer:customer,items:cart.map(i=>({productName:i.productName,sku:i.sku,qty:i.qty,price:i.price})),total:totalSale,cost:totalCost,profit,payment,status:isCredit ? 'Credit' : 'Paid',token,timestamp:Date.now()};
            cart.forEach(item=>{ const p=products.find(x=>x.name===item.productName); if(p) p.sold=(p.sold||0)+item.qty; });
            sales.push(sale); saveState();
            logAudit('sale',`Sale ${sale.saleId}: ${cart.map(i=>i.productName+' x'+i.qty).join(', ')} | ${ksh(totalSale)}`,totalSale,currentUser,token);

            const paymentAccount = payment === 'Cash' ? 'Cash' : (payment === 'M-Pesa' ? 'Bank' : 'Bank');
            if (isCredit) {
                createCreditSale(customer, totalSale, cart.map(i=>({name:i.productName,qty:i.qty,price:i.price})), date);
                alert(`✅ Credit sale ${sale.saleId} created for ${customer}\nTotal: ${ksh(totalSale)}`);
            } else {
                addJournalEntry(`Sale ${sale.saleId} - Revenue`, 'Revenue', 0, totalSale, date, currentUser);
                addJournalEntry(`Sale ${sale.saleId} - Payment`, paymentAccount, totalSale, 0, date, currentUser);
                addJournalEntry(`Sale ${sale.saleId} - COGS`, 'COGS', totalCost, 0, date, currentUser);
                addJournalEntry(`Sale ${sale.saleId} - Inventory Reduction`, 'Inventory', 0, totalCost, date, currentUser);
                alert(`✅ Sale ${sale.saleId} complete!\nTotal: ${ksh(totalSale)}`);
            }
            cart=[]; renderCart(); renderAll(); checkLowStock();
        }

