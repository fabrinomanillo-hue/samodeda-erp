    <script>
        // ========================== FIREBASE CONFIGURATION ==========================
        // REPLACE WITH YOUR FIREBASE CONFIG FROM FIREBASE CONSOLE
        const firebaseConfig = {
            apiKey: "YOUR_API_KEY",
            authDomain: "YOUR_PROJECT.firebaseapp.com",
            databaseURL: "https://YOUR_PROJECT-default-rtdb.firebaseio.com",
            projectId: "YOUR_PROJECT",
            storageBucket: "YOUR_PROJECT.appspot.com",
            messagingSenderId: "YOUR_SENDER_ID",
            appId: "YOUR_APP_ID"
        };

        let firebaseInitialized = false;
        let realtimeDb = null;
        let auth = null;
        let firebaseUser = null;

        function initFirebase() {
            try {
                firebase.initializeApp(firebaseConfig);
                realtimeDb = firebase.database();
                auth = firebase.auth();
                firebaseInitialized = true;
                document.getElementById('firebaseStatus').textContent = '✅ Firebase Connected';
                document.getElementById('firebaseStatus').style.color = '#38a169';
                
                // Auth state listener
                auth.onAuthStateChanged(user => {
                    if (user) {
                        firebaseUser = user;
                        document.getElementById('firebaseUser').textContent = `👤 ${user.email || user.uid}`;
                        document.getElementById('onlineStatus').className = 'online-status online';
                        // Load data from Firebase
                        loadFromFirebase();
                    } else {
                        firebaseUser = null;
                        document.getElementById('firebaseUser').textContent = '🔒 Not signed in to Firebase';
                        document.getElementById('onlineStatus').className = 'online-status offline';
                    }
                });
                
                // Listen for real-time updates
                setupRealtimeListeners();
                
            } catch(e) {
                console.error('Firebase init error:', e);
                document.getElementById('firebaseStatus').textContent = '❌ Firebase Error: ' + e.message;
                document.getElementById('firebaseStatus').style.color = '#e53e3e';
                // Fallback to localStorage sync
                startPolling();
            }
        }

        // ========================== REAL-TIME SYNC ==========================
        let syncListeners = [];
        let isSyncing = false;

        function setupRealtimeListeners() {
            if (!realtimeDb) return;
            
            // Listen for products changes
            const productsRef = realtimeDb.ref('samodeda/products');
            productsRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    const newProducts = Object.values(data);
                    if (JSON.stringify(newProducts) !== JSON.stringify(products)) {
                        products = newProducts;
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                }
            });

            // Listen for sales changes
            const salesRef = realtimeDb.ref('samodeda/sales');
            salesRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    const newSales = Object.values(data);
                    if (JSON.stringify(newSales) !== JSON.stringify(sales)) {
                        sales = newSales;
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                }
            });

            // Listen for credit sales changes
            const creditRef = realtimeDb.ref('samodeda/credit');
            creditRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    const newCredit = Object.values(data);
                    if (JSON.stringify(newCredit) !== JSON.stringify(creditSales)) {
                        creditSales = newCredit;
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                }
            });

            // Listen for restocks changes
            const restockRef = realtimeDb.ref('samodeda/restocks');
            restockRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    const newRestocks = Object.values(data);
                    if (JSON.stringify(newRestocks) !== JSON.stringify(restocks)) {
                        restocks = newRestocks;
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                }
            });

            // Listen for ledger changes
            const ledgerRef = realtimeDb.ref('samodeda/ledger');
            ledgerRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    const newLedger = Object.values(data);
                    if (JSON.stringify(newLedger) !== JSON.stringify(ledgerEntries)) {
                        ledgerEntries = newLedger;
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                }
            });

            // Listen for journal changes
            const journalRef = realtimeDb.ref('samodeda/journals');
            journalRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (data) {
                    const newJournals = Object.values(data);
                    if (JSON.stringify(newJournals) !== JSON.stringify(journalEntries)) {
                        journalEntries = newJournals;
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                    }
                }
            });
        }

        function loadFromFirebase() {
            if (!realtimeDb) return;
            updateSyncStatus('Syncing...');
            
            const refs = {
                products: realtimeDb.ref('samodeda/products'),
                sales: realtimeDb.ref('samodeda/sales'),
                credit: realtimeDb.ref('samodeda/credit'),
                restocks: realtimeDb.ref('samodeda/restocks'),
                ledger: realtimeDb.ref('samodeda/ledger'),
                journals: realtimeDb.ref('samodeda/journals')
            };

            let loaded = 0;
            const total = Object.keys(refs).length;

            Object.entries(refs).forEach(([key, ref]) => {
                ref.once('value').then((snapshot) => {
                    const data = snapshot.val();
                    if (data) {
                        const values = Object.values(data);
                        switch(key) {
                            case 'products': products = values; break;
                            case 'sales': sales = values; break;
                            case 'credit': creditSales = values; break;
                            case 'restocks': restocks = values; break;
                            case 'ledger': ledgerEntries = values; break;
                            case 'journals': journalEntries = values; break;
                        }
                    }
                    loaded++;
                    if (loaded === total) {
                        saveState();
                        renderAll();
                        updateSyncStatus('Synced');
                        document.getElementById('onlineStatus').className = 'online-status online';
                    }
                }).catch((e) => {
                    console.error('Error loading from Firebase:', e);
                    document.getElementById('onlineStatus').className = 'online-status offline';
                });
            });
        }

        function pushToFirebase(path, data) {
            if (!realtimeDb || !firebaseUser) return;
            try {
                const ref = realtimeDb.ref(path);
                const newRef = ref.push();
                // Add metadata
                const payload = {
                    ...data,
                    _syncedAt: Date.now(),
                    _syncedBy: firebaseUser.uid,
                    _syncedByEmail: firebaseUser.email
                };
                newRef.set(payload);
            } catch(e) {
                console.error('Error pushing to Firebase:', e);
                // Fallback to localStorage
                saveState();
            }
        }

        // Override saveState to sync with Firebase
        const originalSaveState = saveState;
        saveState = function() {
            // Save locally
            localStorage.setItem('samodeda_products', JSON.stringify(products));
            localStorage.setItem('samodeda_sales', JSON.stringify(sales));
            localStorage.setItem('samodeda_credit', JSON.stringify(creditSales));
            localStorage.setItem('samodeda_restocks', JSON.stringify(restocks));
            localStorage.setItem('samodeda_ledger', JSON.stringify(ledgerEntries));
            localStorage.setItem('samodeda_journals', JSON.stringify(journalEntries));
            localStorage.setItem('samodeda_saleIdCounter', JSON.stringify(saleIdCounter));
            
            // Push to Firebase if connected
            if (realtimeDb && firebaseUser) {
                updateSyncStatus('Syncing...');
                document.getElementById('onlineStatus').className = 'online-status syncing';
                
                const updates = {
                    products: products,
                    sales: sales,
                    credit: creditSales,
                    restocks: restocks,
                    ledger: ledgerEntries,
                    journals: journalEntries
                };
                
                Object.entries(updates).forEach(([key, data]) => {
                    const ref = realtimeDb.ref(`samodeda/${key}`);
                    // Use set to maintain structure
                    const dataObj = {};
                    data.forEach(item => {
                        const id = item.id || item.saleId || item.sku || 'item_' + Date.now() + '_' + Math.random().toString(36).substr(2, 4);
                        dataObj[id] = { ...item, _syncedAt: Date.now(), _syncedBy: firebaseUser.uid };
                    });
                    ref.set(dataObj);
                });
                
                setTimeout(() => {
                    updateSyncStatus('Synced');
                    document.getElementById('onlineStatus').className = 'online-status online';
                }, 500);
            }
            
            broadcastUpdate();
        };

        // ========================== AUTHENTICATION ==========================
        // Firebase authentication integration
        function loginWithFirebase(email, password) {
            if (!auth) {
                // Fallback to local login
                return loginLocal(email, password);
            }
            
            return auth.signInWithEmailAndPassword(email, password)
                .then((userCredential) => {
                    firebaseUser = userCredential.user;
                    document.getElementById('firebaseUser').textContent = `👤 ${firebaseUser.email}`;
                    document.getElementById('onlineStatus').className = 'online-status online';
                    // Load data from Firebase
                    loadFromFirebase();
                    return true;
                })
                .catch((error) => {
                    console.error('Firebase login error:', error);
                    // Fallback to local login
                    return loginLocal(email, password);
                });
        }

        function loginLocal(username, password) {
            const user = userDB[username];
            if (!user || user.password !== password) return false;
            currentUser = username;
            sessionToken = generateSessionToken(username);
            sessionStart = Date.now();
            document.getElementById('loginOverlay').classList.add('hidden');
            document.getElementById('currentUserDisplay').textContent = user.display || username;
            document.getElementById('sessionTokenDisplay').textContent = sessionToken.substring(0,16)+'…';
            logAudit('login', `User ${username} logged in`, 0, username, 'system');
            localStorage.setItem('samodeda_current_user', username);
            renderAll();
            return true;
        }

        // Override login function
        const originalLogin = login;
        login = function(username, password) {
            // Try Firebase login first if available
            if (auth) {
                // For Firebase, we need email format
                const email = username.includes('@') ? username : `${username}@samodeda.com`;
                return loginWithFirebase(email, password);
            }
            return loginLocal(username, password);
        };

        // ========================== INSTALL APP (PWA) ==========================
        let deferredPrompt;

        function installApp() {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        console.log('User accepted the install prompt');
                    } else {
                        console.log('User dismissed the install prompt');
                    }
                    deferredPrompt = null;
                });
            } else {
                // Create PWA manifest dynamically
                createManifest();
                // Show instructions
                alert('To install this app:\n\n' +
                      '1. On Android: Open in Chrome, tap the menu (⋮) → "Add to Home screen"\n' +
                      '2. On iOS: Open in Safari, tap Share → "Add to Home Screen"\n' +
                      '3. On Desktop: Open in Chrome, click the install icon in the address bar\n\n' +
                      'The app will work offline once installed!');
            }
        }

        function createManifest() {
            const manifest = {
                name: "Samodeda ERP",
                short_name: "Samodeda",
                description: "Complete ERP System for Samodeda Limited",
                start_url: window.location.href,
                display: "standalone",
                background_color: "#1a1a2e",
                theme_color: "#1a1a2e",
                icons: [
                    {
                        src: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' fill='%231a1a2e'/%3E%3Ctext x='256' y='340' font-size='300' text-anchor='middle' fill='%23f5b042' font-family='Arial'%3E🏪%3C/text%3E%3C/svg%3E",
                        sizes: "512x512",
                        type: "image/svg+xml",
                        purpose: "any maskable"
                    }
                ]
            };
            
            const manifestBlob = new Blob([JSON.stringify(manifest)], { type: 'application/json' });
            const manifestURL = URL.createObjectURL(manifestBlob);
            
            // Check if manifest already exists
            let manifestLink = document.querySelector('link[rel="manifest"]');
            if (!manifestLink) {
                manifestLink = document.createElement('link');
                manifestLink.rel = 'manifest';
                document.head.appendChild(manifestLink);
            }
            manifestLink.href = manifestURL;
            
            // Register service worker
            registerServiceWorker();
        }

        function registerServiceWorker() {
            if ('serviceWorker' in navigator) {
                // Create a simple service worker
                const swCode = `
                    const CACHE_NAME = 'samodeda-v1';
                    const urlsToCache = [
                        '${window.location.pathname}',
                        '${window.location.pathname}?v=1'
                    ];

                    self.addEventListener('install', event => {
                        event.waitUntil(
                            caches.open(CACHE_NAME)
                                .then(cache => cache.addAll(urlsToCache))
                        );
                    });

                    self.addEventListener('fetch', event => {
                        event.respondWith(
                            caches.match(event.request)
                                .then(response => response || fetch(event.request))
                        );
                    });

                    self.addEventListener('activate', event => {
                        event.waitUntil(
                            caches.keys().then(cacheNames => {
                                return Promise.all(
                                    cacheNames.map(cacheName => {
                                        if (cacheName !== CACHE_NAME) {
                                            return caches.delete(cacheName);
                                        }
                                    })
                                );
                            })
                        );
                    });
                `;
                
                const swBlob = new Blob([swCode], { type: 'application/javascript' });
                const swURL = URL.createObjectURL(swBlob);
                
                navigator.serviceWorker.register(swURL)
                    .then(registration => {
                        console.log('Service Worker registered successfully');
                    })
                    .catch(error => {
                        console.log('Service Worker registration failed:', error);
                    });
            }
        }

        // Listen for beforeinstallprompt event
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            // Show install button
            document.querySelector('.app-download-btn').style.display = 'inline-flex';
        });

        // ========================== NETWORK STATUS ==========================
        function updateNetworkStatus() {
            const statusEl = document.getElementById('onlineStatus');
            if (navigator.onLine) {
                if (realtimeDb && firebaseUser) {
                    statusEl.className = 'online-status online';
                    updateSyncStatus('Connected');
                } else {
                    statusEl.className = 'online-status offline';
                    updateSyncStatus('Offline');
                }
            } else {
                statusEl.className = 'online-status offline';
                updateSyncStatus('Offline (local mode)');
            }
        }

        window.addEventListener('online', updateNetworkStatus);
        window.addEventListener('offline', updateNetworkStatus);

        // ========================== EXPORT DATA FOR BACKUP ==========================
        function exportAllData() {
            const data = {
                products: products,
                sales: sales,
                creditSales: creditSales,
                restocks: restocks,
                miscEntries: miscEntries,
                ledgerEntries: ledgerEntries,
                journalEntries: journalEntries,
                suppliers: suppliers,
                customers: customers,
                taxEntries: taxEntries,
                budgetEntries: budgetEntries,
                userDB: userDB,
                exportDate: new Date().toISOString(),
                version: '1.0'
            };
            
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `samodeda_backup_${todayStr()}.json`;
            a.click();
            URL.revokeObjectURL(url);
            alert('✅ Data exported successfully!');
        }

        function importAllData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = function(e) {
                const file = e.target.files[0];
                const reader = new FileReader();
                reader.onload = function(event) {
                    try {
                        const data = JSON.parse(event.target.result);
                        if (data.products) products = data.products;
                        if (data.sales) sales = data.sales;
                        if (data.creditSales) creditSales = data.creditSales;
                        if (data.restocks) restocks = data.restocks;
                        if (data.miscEntries) miscEntries = data.miscEntries;
                        if (data.ledgerEntries) ledgerEntries = data.ledgerEntries;
                        if (data.journalEntries) journalEntries = data.journalEntries;
                        if (data.suppliers) suppliers = data.suppliers;
                        if (data.customers) customers = data.customers;
                        if (data.taxEntries) taxEntries = data.taxEntries;
                        if (data.budgetEntries) budgetEntries = data.budgetEntries;
                        if (data.userDB) userDB = data.userDB;
                        saveState();
                        renderAll();
                        alert('✅ Data imported successfully!');
                    } catch(err) {
                        alert('❌ Error importing data: ' + err.message);
                    }
                };
                reader.readAsText(file);
            };
            input.click();
        }

        // Add export/import buttons to the UI
        document.addEventListener('DOMContentLoaded', function() {
            const headerRight = document.querySelector('.header-right');
            const exportBtn = document.createElement('button');
            exportBtn.className = 'btn btn-sm btn-info';
            exportBtn.innerHTML = '<i class="fas fa-download"></i> Export';
            exportBtn.onclick = exportAllData;
            headerRight.appendChild(exportBtn);
            
            const importBtn = document.createElement('button');
            importBtn.className = 'btn btn-sm btn-warning';
            importBtn.innerHTML = '<i class="fas fa-upload"></i> Import';
            importBtn.onclick = importAllData;
            headerRight.appendChild(importBtn);
        });

        // ========================== INITIALIZATION ==========================
        // Initialize Firebase first
        initFirebase();
        
        // Then initialize data
        initData();

        // Render everything
        const savedUser = localStorage.getItem('samodeda_current_user');
        if(savedUser && userDB[savedUser]){ 
            currentUser = savedUser; 
            sessionToken = generateSessionToken(savedUser); 
            sessionStart = Date.now(); 
            document.getElementById('loginOverlay').classList.add('hidden'); 
            document.getElementById('currentUserDisplay').textContent = userDB[savedUser].display||savedUser; 
            document.getElementById('sessionTokenDisplay').textContent = sessionToken.substring(0,16)+'…'; 
        }
        renderAll();
        
        // Check network status
        updateNetworkStatus();
        
        console.log(`🏢 Samodeda Ltd Real-Time ERP loaded`);
        console.log(`📡 Firebase: ${firebaseInitialized ? 'Connected' : 'Disconnected (local mode)'}`);
        console.log(`📦 ${products.length} products, ${Object.keys(userDB).length} users`);
        console.log(`📒 ${ledgerEntries.length} ledger entries, ${journalEntries.length} journal entries`);
    </script>
</body>
