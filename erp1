        // ===== CREDIT FUNCTIONS =====
        function createCreditSale(customer, total, items, date) {
            const id = 'CR-' + String(saleIdCounter++).padStart(5,'0');
            const entry = {
                id: id,
                date: date || todayStr(),
                customer: customer || 'Walk-in',
                total: total,
                paid: 0,
                balance: total,
                items: items || [],
                user: currentUser,
                status: 'unpaid',
                timestamp: Date.now()
            };
            creditSales.push(entry);
            saveState();
            logAudit('credit', `Credit sale ${id} to ${customer} for ${ksh(total)}`, total, currentUser, 'system');
            addJournalEntry(`Credit sale ${id} to ${customer}`, 'Receivables', total, 0, date, currentUser);
            addJournalEntry(`Credit sale ${id} - Revenue`, 'Revenue', 0, total, date, currentUser);
            // Update customer balance
            let cust = customers.find(c => c.name === customer);
            if (cust) { cust.balance = (cust.balance || 0) + total; }
            else { customers.push({ name: customer, contact: '', balance: total }); }
            saveState();
            renderCredit();
            return entry;
        }

        function recordCreditPayment(id, amount) {
            const credit = creditSales.find(c => c.id === id);
            if (!credit) { alert('Credit record not found.'); return; }
            if (amount > credit.balance) { alert('Payment exceeds balance.'); return; }
            credit.paid = (credit.paid || 0) + amount;
            credit.balance = credit.total - credit.paid;
            if (credit.balance <= 0.01) { credit.status = 'paid'; }
            else if (credit.paid > 0) { credit.status = 'partial'; }
            saveState();
            logAudit('credit', `Payment of ${ksh(amount)} on ${id}`, amount, currentUser, 'system');
            addJournalEntry(`Payment on credit ${id}`, 'Cash', amount, 0, todayStr(), currentUser);
            addJournalEntry(`Payment on credit ${id}`, 'Receivables', 0, amount, todayStr(), currentUser);
            // Update customer balance
            let cust = customers.find(c => c.name === credit.customer);
            if (cust) { cust.balance = (cust.balance || 0) - amount; }
            saveState();
            renderCredit();
            alert(`✅ Payment of ${ksh(amount)} recorded. Remaining balance: ${ksh(credit.balance)}`);
        }

