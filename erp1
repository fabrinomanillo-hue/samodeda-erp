        function addLedgerEntry() {
            if (!currentUser) { alert('Please login first.'); return; }
            const date = document.getElementById('ledgerDate').value || todayStr();
            const desc = document.getElementById('ledgerDesc').value.trim();
            const debit = parseFloat(document.getElementById('ledgerDebit').value) || 0;
            const credit = parseFloat(document.getElementById('ledgerCredit').value) || 0;
            const account = document.getElementById('ledgerAccount').value;
            if (!desc) { alert('Please enter a description.'); return; }
            if (debit === 0 && credit === 0) { alert('Please enter either a debit or credit amount.'); return; }
            if (debit > 0 && credit > 0) { alert('Please enter only debit OR credit, not both.'); return; }
            postLedger(desc, debit, credit, account);
            addJournalEntry(desc, account, debit, credit, date, currentUser);
            document.getElementById('ledgerDesc').value = '';
            document.getElementById('ledgerDebit').value = '';
            document.getElementById('ledgerCredit').value = '';
        }

        function renderLedger() {
            const container = document.getElementById('ledgerEntries');
            const date = document.getElementById('ledgerDate').value || todayStr();
            const filtered = ledgerEntries.filter(e => e.date === date);
            document.getElementById('ledgerCountBadge').textContent = filtered.length + ' entries';
            if (filtered.length === 0) {
                container.innerHTML = '<div style="text-align:center;padding:10px;color:#a0aec0;font-size:0.7rem;">No ledger entries for this day.</div>';
            } else {
                let runningBalance = 0;
                container.innerHTML = filtered.map(e => {
                    runningBalance += (e.debit || 0) - (e.credit || 0);
                    return `<div class="ledger-entry">
                        <span class="ledger-desc">${e.description} <span style="font-size:0.5rem;color:#718096;">(${e.account})</span></span>
                        ${e.debit > 0 ? `<span class="ledger-debit">${ksh(e.debit)}</span>` : ''}
                        ${e.credit > 0 ? `<span class="ledger-credit">${ksh(e.credit)}</span>` : ''}
                        <span class="ledger-balance">${ksh(runningBalance)}</span>
                    </div>`;
                }).join('');
            }
            const totalDebit = filtered.reduce((sum, e) => sum + (e.debit || 0), 0);
            const totalCredit = filtered.reduce((sum, e) => sum + (e.credit || 0), 0);
            document.getElementById('ledgerTotalDebit').textContent = ksh(totalDebit);
            document.getElementById('ledgerTotalCredit').textContent = ksh(totalCredit);
            document.getElementById('ledgerNetBalance').textContent = ksh(totalDebit - totalCredit);
            const accountBalances = {};
            ledgerEntries.forEach(e => {
                const acct = e.account || 'Other';
                if (!accountBalances[acct]) accountBalances[acct] = 0;
                accountBalances[acct] += (e.debit || 0) - (e.credit || 0);
            });
            const balContainer = document.getElementById('accountBalances');
            balContainer.innerHTML = Object.keys(accountBalances).map(acct => `
                <div class="account-card">
                    <span class="account-name">${acct}</span>
                    <span class="account-balance ${accountBalances[acct] >= 0 ? 'positive' : 'negative'}">${ksh(accountBalances[acct])}</span>
                </div>
            `).join('');
        }

        function setLedgerPeriod(days) {
            const date = new Date();
            if (days === 'today') { document.getElementById('ledgerDate').value = todayStr(); }
            else if (days === 'week') { const d = new Date(); d.setDate(d.getDate() - 7); document.getElementById('ledgerDate').value = d.toISOString().slice(0,10); }
            else if (days === 'month') { const d = new Date(); d.setMonth(d.getMonth() - 1); document.getElementById('ledgerDate').value = d.toISOString().slice(0,10); }
            else if (days === 'all') { document.getElementById('ledgerDate').value = ''; }
            renderLedger();
        }

